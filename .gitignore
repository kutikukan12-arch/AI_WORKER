# =====================================================
# AI_WORKER .gitignore
# =====================================================

# ─── 秘密情報（絶対にコミット禁止）───
.env
*.env.local
*.env.*.local
.env.bak*
*.env.bak*
docs/*.env

# ─── Node.js ───
node_modules/
npm-debug.log*

# ─── 運用データ（実行時に生成・個人情報含む可能性あり）───
data/tasks.json
data/approvals.json
data/archive_tasks.json
data/bot.pid
data/*.pid
data/bot.lock
data/restart.lock
data/restart-state.json
data/history/
data/apply-counts.json
data/current-project.json
data/runner-state.json
data/fix-counts.json
data/projects.json
data/workers.json
data/ml-models.json
data/security-events.json

# ─── 調査レポート（実行時に生成・大量蓄積）───
reports/

# ─── レビューファイル（大量蓄積・個人情報含む可能性あり）───
reviews/

# ─── 作業ワークスペース（タスクごとの一時ファイル）───
workspace/

# ─── ログ（大量になるため除外・.gitkeep は維持）───
logs/*.log
logs/*.txt

# ─── 自動生成ドキュメント（実行時に上書きされる）───
docs/history/
docs/meetings/
docs/batch_*.md
docs/next_task.md

# ─── 一時ファイル ───
temp/

# ─── Windows 固有ファイル ───
Thumbs.db
Desktop.ini

# ─── エディタ設定 ───
.vscode/
.idea/

# ─── 維持するファイル（! で除外対象から除く）───
!logs/.gitkeep
!.env.example
data/workers.json
data/quality-gates.json
data/pending-plans.json
data/project-insights.json
data/client-projects.json
data/sales-learning.json
data/daily-changes.json
data/pending-rules.json
data/decisions.json
data/incidents.json
data/internal-messages.json

# ─── Desktop Inbox Bridge / Agent（社内情報・外部公開禁止）─────
data/inbox/
data/outbox/
data/desktop-agent/

# ─── 顧客案件学習データ（個人情報漏洩防止）───
learning/
data/finance-config.json
data/finance-approval.json

# ─── YouTube診断AI: training model / data（公開禁止）────
# training model（生の学習重み + 付帯情報）
data/youtube-model.json
data/youtube-model-pre.json
# 元データセット（収集済み YouTube データ）
data/youtube-seeds/

# ─── YouTube診断AI: 推論専用 export（Web 側に渡す）────
# export モデル（weights のみ・training metadata 除外済み）
# このファイルは公開可能。ただし意図的に commit する場合のみ !で除外を解除する。
# data/youtube-model-export.json
