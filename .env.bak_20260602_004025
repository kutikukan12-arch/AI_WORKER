# ════════════════════════════════════════
# Phase3 設定: PR作成・自動フィードバック
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase3] PR 作成を有効にするか
# true にするとフィーチャーブランチを作成してPRを自動生成します
# ENABLE_GITHUB=true も同時に設定してください
#
# 注意:
#   PR の自動マージは行いません。
#   必ず人間が GitHub でレビューしてからマージしてください。
# ─────────────────────────────────────
ENABLE_PR=false

# ─────────────────────────────────────
# [Phase3] Codex 自動フィードバックを有効にするか
# true かつ OPENAI_API_KEY が設定されている場合、
# Claude Code 完了後に Codex API を呼び出して
# 自動でフィードバックを適用します
#
# 注意: API 呼び出しには費用が発生します！
# ─────────────────────────────────────
ENABLE_AUTO_FEEDBACK=false

# ─────────────────────────────────────
