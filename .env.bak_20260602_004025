# ════════════════════════════════════════
# Phase4 設定: タスク管理・ナイトバッチ・AI会議
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase4] ナイトバッチを有効にするか（デフォルト: true）
# false にするとバッチ処理を完全に無効化します
# ─────────────────────────────────────
BATCH_ENABLED=true

# ─────────────────────────────────────
# [Phase4] バッチ実行時刻（24時間制）
# 例: 2時00分 → BATCH_HOUR=2 / BATCH_MINUTE=0
# ─────────────────────────────────────
BATCH_HOUR=2
BATCH_MINUTE=0

# ─────────────────────────────────────
# [Phase4] バッチ最大実行回数（0=無制限）
# テスト用に 1 を指定するとバッチを1回で自動停止します
# ─────────────────────────────────────
BATCH_MAX_RUNS=0

# ─────────────────────────────────────
# [Phase4] バッチ通知専用 Discord チャンネル（#night-batch 等）
# 空欄にすると通知されません
# ─────────────────────────────────────
