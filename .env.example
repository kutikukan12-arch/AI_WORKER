# =====================================================
# AI_WORKER Bot 環境変数テンプレート（Phase2対応版）
# このファイルをコピーして .env を作成してください
#   コマンド: Copy-Item .env.example .env
#
# ⚠️ 注意:
#   - このファイル (.env.example) は Git 管理対象です
#   - .env (実際の値) は .gitignore 対象 — コミット禁止
#   - 実際のトークン/キーは .env にのみ記載してください
# =====================================================

# ════════════════════════════════════════
# Phase1 設定（必須）
# ════════════════════════════════════════

# ─────────────────────────────────────
# [必須] Discord Bot トークン
# 取得手順:
#   1. https://discord.com/developers/applications を開く
#   2. 「New Application」でアプリを作成
#   3. 左メニュー「Bot」→「Reset Token」でトークン取得
# ─────────────────────────────────────
DISCORD_TOKEN=<your-discord-bot-token>

# ─────────────────────────────────────
# [必須] 監視するチャンネルのID（カンマ区切りで複数可）
# 取得方法: Discordで開発者モードON → チャンネル右クリック → IDをコピー
# ─────────────────────────────────────
ALLOWED_CHANNEL_IDS=111111111111111111,222222222222222222

# ─────────────────────────────────────
# [必須] あなたの Discord ユーザーID（危険作業時メンション）
# 取得方法: Discordで開発者モードON → 自分を右クリック → IDをコピー
# ─────────────────────────────────────
DISCORD_OWNER_ID=your-discord-user-id

# ─────────────────────────────────────
# [任意] Claude Code の実行コマンド（通常は変更不要）
# ─────────────────────────────────────
CLAUDE_COMMAND=claude.cmd

# ─────────────────────────────────────
# [任意] タスクのタイムアウト（秒）デフォルト: 5分
# ─────────────────────────────────────
TASK_TIMEOUT_SECONDS=300

# ─────────────────────────────────────
# [任意] 同時実行タスク数（推奨: 1）
# ─────────────────────────────────────
MAX_CONCURRENT_TASKS=1


# ════════════════════════════════════════
# Phase2 設定: GitHub 連携
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase2] GitHub 連携を有効にするか
# true にすると Claude Code 完了後に自動コミット・Push します
# ─────────────────────────────────────
ENABLE_GITHUB=true

# ─────────────────────────────────────
# [Phase2] GitHub Personal Access Token
# 取得手順:
#   1. GitHub を開く
#   2. 右上のアイコン → Settings → Developer settings
#   3. Personal access tokens → Tokens (classic)
#   4. Generate new token → repo にチェック → 生成
#
# 注意: このトークンは他人に教えないでください！
# ─────────────────────────────────────
GITHUB_TOKEN=<your-github-personal-access-token>

# ─────────────────────────────────────
# [Phase2] GitHub リポジトリ名（username/repo 形式）
# 例: tanaka/ai-worker-output
# ─────────────────────────────────────
GITHUB_REPO=your-username/AI_WORKER

# ─────────────────────────────────────
# [Phase2] Push するブランチ名（デフォルト: main）
# ─────────────────────────────────────
GITHUB_BRANCH=main

# ─────────────────────────────────────
# [Phase2] git コミット対象フォルダ（デフォルト: AI_WORKERルート）
# 例: D:\Projects\my-app
# ─────────────────────────────────────
GIT_REPO_PATH=D:/path/to/AI_WORKER


# ════════════════════════════════════════
# Phase2 設定: Codex（OpenAI）連携
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase2] Codex 連携を有効にするか
# false でも「Codexが必要そう」と判断した場合は依頼文を生成します
# true にすると常に Codex 依頼文を生成します
# ─────────────────────────────────────
ENABLE_CODEX=true

# ─────────────────────────────────────
# [Phase2] OpenAI API キー（任意: 直接API呼び出し用）
# 未設定の場合は依頼文の生成のみ行います（APIは呼び出しません）
# 注意: API呼び出しには費用が発生します！
# 取得: https://platform.openai.com/api-keys
# ─────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>


# ════════════════════════════════════════
# Phase2 設定: Discord 専用チャンネル
# ════════════════════════════════════════
# 空欄にすると全通知がコマンドチャンネルに届きます

# ─────────────────────────────────────
# [Phase2] GitHub 操作ログ専用チャンネル（#github-log 等）
# ─────────────────────────────────────
GITHUB_LOG_CHANNEL_ID=

# ─────────────────────────────────────
# [Phase2] AI レビュー結果専用チャンネル（#ai-review 等）
# ─────────────────────────────────────
AI_REVIEW_CHANNEL_ID=

# ─────────────────────────────────────
# [Phase2] Codex レビュー依頼専用チャンネル（#codex-review 等）
# ─────────────────────────────────────
CODEX_REVIEW_CHANNEL_ID=


# ════════════════════════════════════════
# Phase3 設定: PR作成・自動フィードバック
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase3] PR 作成を有効にするか
# ─────────────────────────────────────
ENABLE_PR=false

# ─────────────────────────────────────
# [Phase3] Codex 自動フィードバックを有効にするか
# 注意: API 呼び出しには費用が発生します！
# ─────────────────────────────────────
ENABLE_AUTO_FEEDBACK=false

# ─────────────────────────────────────
# [Phase3] PR 通知専用 Discord チャンネル（#pr-review 等）
# ─────────────────────────────────────
PR_CHANNEL_ID=

# ─────────────────────────────────────
# [Phase3] レビュー履歴通知専用チャンネル（#ai-history 等）
# ─────────────────────────────────────
HISTORY_CHANNEL_ID=


# ════════════════════════════════════════
# Phase4 設定: タスク管理・ナイトバッチ・AI会議
# ════════════════════════════════════════

# ─────────────────────────────────────
# [Phase4] ナイトバッチを有効にするか（デフォルト: true）
# ─────────────────────────────────────
BATCH_ENABLED=true

# ─────────────────────────────────────
# [Phase4] バッチ実行時刻（24時間制）
# ─────────────────────────────────────
BATCH_HOUR=2
BATCH_MINUTE=0

# ─────────────────────────────────────
# [Phase4] バッチ最大実行回数（0=無制限）
# ─────────────────────────────────────
BATCH_MAX_RUNS=0

# ─────────────────────────────────────
# [Phase4] バッチ通知専用 Discord チャンネル
# ─────────────────────────────────────
BATCH_CHANNEL_ID=
MORNING_BATCH_CHANNEL_ID=

# ─────────────────────────────────────
# [Phase4] AI 会議結果専用チャンネル（#ai-meeting 等）
# ─────────────────────────────────────
MEETING_CHANNEL_ID=

# ─────────────────────────────────────
# [Phase6] エラー通知専用チャンネル（#error-log 等）
# ─────────────────────────────────────
ERROR_CHANNEL_ID=


# ════════════════════════════════════════
# 🏢 Discord 再編成（CEO Report / AI Board）
# ════════════════════════════════════════

# 📊 日報ダッシュボード（CEO Report: 社長が毎朝見る場所）
CEO_REPORT_CHANNEL_ID=

# 🧠 AI Board Report（技術的完成度・品質状態レポート）
AI_BOARD_CHANNEL_ID=

# ✋ 承認まち
HUMAN_CHECK_CHANNEL_ID=


# ════════════════════════════════════════
# 🤝 Natural CEO Interface
# CEO が自然文で Bot を操作するための設定
#
# 「Bot動いてる？」「進めて」「今日どうだった？」など
# 自然な日本語で AI_WORKER を操作できる機能です。
# ════════════════════════════════════════

# ─────────────────────────────────────
# [CEO操作] CEO の Discord ユーザーID（カンマ区切りで複数可）
# ⚠️ チャンネルIDではなくユーザーIDです
#
# 未設定のままにすると自然文CEOコマンドは無効になります（安全側）
# ボタン承認（Approval Card）も操作できなくなります。
#
# 取得方法:
#   1. Discord 設定 → 詳細設定 → 開発者モード を ON にする
#   2. 自分のアカウントを右クリック → 「IDをコピー」」
#   3. 以下にペーストして Bot を再起動
#
# 例（複数指定）: CEO_USER_IDS=111111111111111111,222222222222222222
# ─────────────────────────────────────
CEO_USER_IDS=1154113366374228079


# ════════════════════════════════════════
# YouTube 視聴予測 AI
# ════════════════════════════════════════

# ─────────────────────────────────────
# [YouTube] Google API キー（YouTube Data API v3）
# 取得手順:
#   1. https://console.cloud.google.com/ → APIとサービス → 認証情報
#   2. 「認証情報を作成」→「APIキー」
#   3. YouTube Data API v3 を有効化
# 無料枠: 10,000 units/日
# ─────────────────────────────────────
YOUTUBE_API_KEY=


# ════════════════════════════════════════
# 📡 Role Channel Router (Phase2 / Internal Router)
# 社員ごとの Discord 送信先チャンネル ID
#
# 目的:
#   Bot が社員間ハンドオフを社員別チャンネルへ直接配送する。
#   未設定の社員はコマンドチャンネルへの返信 (fallback) になる。
#   必要な社員分だけ設定すれば良い。
#
# 設定方法:
#   1. Discord 開発者モードを ON にする
#   2. 対象チャンネルを右クリック → 「IDをコピー」
#   3. 以下の = の右にペーストして保存
#   4. Bot を再起動
#   5. !router status で設定済み/未設定を確認
#
# ⚠️ 禁止:
#   このファイルをリポジトリにコミットしない (.gitignore 対象)
#   token / API key をチャットに貼らない
# ════════════════════════════════════════

# ─────────────────────────────────────
# 【最低限設定】内部ルーター Phase2 の主要ルートに必要
# ─────────────────────────────────────

# 守谷 CTO チャンネル (IMPLEMENT_DONE / TECH_REVIEW_DONE の配送先)
MORIYA_CHANNEL_ID=

# 相沢 CS チャンネル (PM_READY の配送先)
AIZAWA_CHANNEL_ID=

# 黒川 CoS チャンネル (CS_READY / TECH_REVIEW_DONE の配送先)
KUROKAWA_CHANNEL_ID=

# CEO チャンネル (KUROKAWA_SUMMARY の配送先 / 判断必要案件のみ)
CEO_CHANNEL_ID=

# ─────────────────────────────────────
# 【任意設定】全社員チャンネルを分離する場合
# ─────────────────────────────────────

# 宮城 Lead Engineer チャンネル (NEED_FIX / SPEC_READY の配送先)
MIYAGI_CHANNEL_ID=

# 白石 COO チャンネル
SHIRAISHI_CHANNEL_ID=

# 市川 PM チャンネル (REVIEW_READY の配送先)
ICHIKAWA_CHANNEL_ID=

# 金森 CFO チャンネル (COST_REQUIRED の配送先 ※現在手動)
KANEMORI_CHANNEL_ID=

# 育野 Learning チャンネル (LESSON_CANDIDATE / INCIDENT_CANDIDATE の配送先)
IKUNO_CHANNEL_ID=

# 神崎 VP チャンネル (VP_BRIEF_REQUEST / STRATEGY_REVIEW の配送先)
KANZAKI_CHANNEL_ID=
