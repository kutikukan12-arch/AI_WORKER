# =====================================================================
#  Discord 再編成 — チャンネル設定ブロック（コピペ用・コメント付き）
# =====================================================================
#  作成日: 2026-06-02 / 担当: Claude D (Communication/UX)
#
#  ★これは「下書き」です。今動いている .env はまだ触っていません。
#
#  使い方:
#    1. Discord画面で下の【要入力】のチャンネルを作り、IDをコピーして埋める
#    2. このブロックを .env の「チャンネル設定」部分にまるごと上書き
#    3. .env を保存して Bot を再起動
#
#  しくみ:
#    同じIDを2か所に書くと、その通知は1つのチャンネルにまとまります。
#    （＝コードを触らずにチャンネルを統合できる）
# =====================================================================


# ─────────────────────────────────────────────────────────────────────
# 🏢 経営ゾーン（社長が毎日見る場所）
# ─────────────────────────────────────────────────────────────────────

# 📊 日報ダッシュボード — 社長が毎朝ここだけ見ればOKな場所
#    ✅ 作成済み: #📊-日報（カテゴリ「🏢 経営」内）
CEO_REPORT_CHANNEL_ID=1511031466992205935

#    AI役員会レポートも日報に合流させる（同じIDにそろえる）
AI_BOARD_CHANNEL_ID=1511031466992205935


# ─────────────────────────────────────────────────────────────────────
# ✅ 承認ゾーン（「OK?」と聞かれた時だけ見る場所）
# ─────────────────────────────────────────────────────────────────────

# ✋ 承認まち — approve / deny を1か所に集約
#    ✅ 既存の #承認-確認 を使用（社長向けの日本語名・ALLOWED登録済み）
HUMAN_CHECK_CHANNEL_ID=1509547954116104283


# ─────────────────────────────────────────────────────────────────────
# 🚨 緊急ゾーン（鳴ったら困りごと）
# ─────────────────────────────────────────────────────────────────────

# 🚨 緊急アラート（既存の error チャンネルをそのまま使用）
ERROR_CHANNEL_ID=1509548061884682453


# ─────────────────────────────────────────────────────────────────────
# 🧠 作業場ゾーン（PMとAIが使う・社長は普段見なくてよい）
# ─────────────────────────────────────────────────────────────────────

# 🧠 計画・会議（既存の meeting チャンネルをそのまま使用）
MEETING_CHANNEL_ID=1509556635817742346


# ─────────────────────────────────────────────────────────────────────
# 🔧 技術ログゾーン（エンジニアだけ見る倉庫）
# ─────────────────────────────────────────────────────────────────────

# 🔍 コードレビュー — ai-review と codex を1つに統合（同じIDにそろえる）
AI_REVIEW_CHANNEL_ID=1509985929648013492
CODEX_REVIEW_CHANNEL_ID=1509985929648013492

# 🔗 GitHub — Push と PR を1つに統合（同じIDにそろえる）
GITHUB_LOG_CHANNEL_ID=1509548020860194916
PR_CHANNEL_ID=1509548020860194916

# 🗄️ 記録アーカイブ — 全タスク履歴の集約先
HISTORY_CHANNEL_ID=1509557457007935530

# 🩺 診断・バッチ — 夜間/朝バッチの通知先
BATCH_CHANNEL_ID=1510712292298457230
MORNING_BATCH_CHANNEL_ID=1510712292298457230


# =====================================================================
#  ⚠️ この設定でできること / できないこと
# =====================================================================
#  できる（今すぐ・安全）:
#    ・点検3チャンネル → 1つに統合
#    ・GitHub 2チャンネル → 1つに統合
#    ・日報/承認チャンネルの新設
#
#  できない（プログラム小修正が必要・次フェーズ）:
#    ・🚨緊急に「重大なエラーだけ」流す振り分け
#      （今は error チャンネルに全エラーが出る）
#    ・日報の自動生成（記号の羅列を日本語サマリに変換）
# =====================================================================
